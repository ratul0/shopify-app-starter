# Shopify app credentials (from Partners Dashboard > App > API credentials)
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""

# Your app's public URL (Shopify CLI sets this automatically during `bun run dev`)
SHOPIFY_APP_URL=""

# OAuth scopes (comma-separated, must match shopify.app.toml)
SCOPES="write_products"

# Database connection string (SQLite for local dev, swap for PostgreSQL/MySQL in production)
DATABASE_URL="file:dev.sqlite"

# Optional: custom shop domain for multi-tenancy
# SHOP_CUSTOM_DOMAIN=""
